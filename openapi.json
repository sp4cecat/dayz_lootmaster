{
  "openapi": "3.0.3",
  "info": {
    "title": "spacecat DayZ Server API",
    "version": "1.0.0",
    "description": "Localhost-only REST API for a running DayZ server. Two capabilities: (1) on-demand scans of spawned world items in a region (GET /items, /items/near/{playerId}), and (2) mod-facing ingest endpoints the companion Enforce Script mod pushes to / polls (POST /ingest/snapshot, POST /ingest/catalog, GET /ingest/commands, POST /ingest/commands/ack). Bound to 127.0.0.1 only, no authentication by design.\n\nItem scans are synchronous round-trips that enqueue a command and wait for the mod to sweep the region; they return 503 when the mod is not connected. Live remaining-TTL is not exposed by the engine, so lifetimeMax is the configured CE lifetime."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:4317",
      "description": "Local loopback (default port; configurable via PORT)"
    }
  ],
  "tags": [
    {
      "name": "map",
      "description": "Live positions"
    },
    {
      "name": "internal",
      "description": "Mod-facing ingest endpoints; do not call manually"
    }
  ],
  "paths": {
    "/items": {
      "get": {
        "tags": [
          "map"
        ],
        "summary": "On-demand scan of spawned world items in a region",
        "description": "Enqueues a scanItems command; the mod sweeps GetObjectsAtPosition3D around (x,z) at terrain height and posts back each ItemBase's class, displayName, position, damage state, and lifetimeMax. Synchronous round-trip (waits for the mod, ~2-4s). Region-scoped only (radius <= 200 m) — DayZ has no performant map-wide item enumeration. Live remaining-TTL is not exposed by the engine; lifetimeMax is the configured CE lifetime.",
        "operationId": "getItems",
        "parameters": [
          {
            "name": "x",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "World X of the sweep centre."
          },
          {
            "name": "z",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "World Z of the sweep centre."
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 30,
              "maximum": 200
            },
            "description": "Sphere radius in metres (default 30, capped at 200)."
          }
        ],
        "responses": {
          "200": {
            "description": "Items found in the region.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemScan"
                }
              }
            }
          },
          "400": {
            "description": "Missing/invalid x or z.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Mod not connected; live scan unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "504": {
            "description": "The mod did not respond in time; retry.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/items/near/{playerId}": {
      "get": {
        "tags": [
          "map"
        ],
        "summary": "Region scan centred on an online player's position",
        "operationId": "getItemsNear",
        "parameters": [
          {
            "name": "playerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Plain id / steamId / name of an online player."
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 30,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Items near the player.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemScan"
                }
              }
            }
          },
          "404": {
            "description": "Player not found or offline.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "503": {
            "description": "Mod not connected.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "504": {
            "description": "Scan timed out.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/ingest/snapshot": {
      "post": {
        "tags": [
          "internal"
        ],
        "summary": "Mod pushes a live snapshot (players + heartbeat + map)",
        "operationId": "ingestSnapshot",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Snapshot"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stored.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ok"
                }
              }
            }
          }
        }
      }
    },
    "/ingest/catalog": {
      "post": {
        "tags": [
          "internal"
        ],
        "summary": "Mod pushes a catalog chunk (config-derived type detail)",
        "operationId": "ingestCatalog",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogChunk"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Merged.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ok"
                }
              }
            }
          }
        }
      }
    },
    "/ingest/commands": {
      "get": {
        "tags": [
          "internal"
        ],
        "summary": "Mod polls pending admin commands (marks them sent)",
        "operationId": "ingestCommands",
        "responses": {
          "200": {
            "description": "Pending commands.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandsList"
                }
              }
            }
          }
        }
      }
    },
    "/ingest/commands/ack": {
      "post": {
        "tags": [
          "internal"
        ],
        "summary": "Mod reports a command result",
        "operationId": "ingestAck",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Ack"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ok"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Ok": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "Position": {
        "type": "array",
        "description": "World position [x, y, z].",
        "items": {
          "type": "number"
        },
        "minItems": 3,
        "maxItems": 3,
        "example": [
          8056.22,
          3.21,
          2820.32
        ]
      },
      "TypeConfig": {
        "type": "object",
        "nullable": true,
        "description": "Mod-catalog detail for a class; null until the mod pushes the catalog.",
        "properties": {
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inventorySlot": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slots THIS item can occupy."
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slots THIS object exposes for other items."
          },
          "magazines": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Compatible magazine classes (CfgWeapons magazines[]); empty for non-weapons."
          },
          "cargoSize": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "isContainer": {
            "type": "boolean",
            "description": "Descends from Container_Base/DeployableContainer_Base; holds cargo even when itemsCargoSize is absent (grid lives in the p3d)."
          },
          "weight": {
            "type": "number",
            "format": "float"
          },
          "hitpoints": {
            "type": "number",
            "format": "float",
            "description": "Base durability (DamageSystem GlobalHealth Health hitpoints); 0 if none."
          },
          "armor": {
            "type": "array",
            "description": "DamageSystem GlobalArmor, one row per declared damage-type (cfgAmmo class). damage is what that type deals to the zone: 0 = immune, higher = less protection.",
            "items": {
              "$ref": "#/components/schemas/ArmorEntry"
            }
          }
        }
      },
      "ArmorEntry": {
        "type": "object",
        "description": "One GlobalArmor damage-type row. Zone value is -1 when that zone isn't declared (distinct from a declared 0 = full immunity).",
        "properties": {
          "ammo": {
            "type": "string",
            "description": "cfgAmmo/damage-type class name (e.g. Bullet_762x39, FragGrenade, MeleeFist)."
          },
          "health": {
            "type": "number",
            "format": "float",
            "description": "Health-zone damage coefficient; -1 if not declared."
          },
          "blood": {
            "type": "number",
            "format": "float",
            "description": "Blood-zone damage coefficient; -1 if not declared."
          },
          "shock": {
            "type": "number",
            "format": "float",
            "description": "Shock-zone damage coefficient; -1 if not declared."
          }
        }
      },
      "ItemInfo": {
        "type": "object",
        "description": "A spawned world item found by a region scan.",
        "properties": {
          "cls": {
            "type": "string",
            "description": "Config class name (GetType)."
          },
          "displayName": {
            "type": "string",
            "description": "Localized in-game name."
          },
          "pos": {
            "$ref": "#/components/schemas/Position"
          },
          "healthLevel": {
            "type": "integer",
            "enum": [
              0,
              1,
              2,
              3,
              4
            ],
            "description": "0=pristine .. 4=ruined."
          },
          "damageState": {
            "type": "string",
            "enum": [
              "pristine",
              "worn",
              "damaged",
              "badly_damaged",
              "ruined",
              "unknown"
            ]
          },
          "lifetimeMax": {
            "type": "number",
            "description": "Configured CE lifetime in seconds (types.xml <lifetime>). NOT the live remaining TTL, which the engine does not expose."
          }
        }
      },
      "ItemScan": {
        "type": "object",
        "properties": {
          "center": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "z": {
                "type": "number"
              }
            }
          },
          "radius": {
            "type": "number"
          },
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemInfo"
            }
          }
        }
      },
      "Snapshot": {
        "type": "object",
        "description": "Free-form live-state blob pushed by the mod (players, server heartbeat, worldMap). Stored as-is.",
        "additionalProperties": true
      },
      "CatalogChunk": {
        "type": "object",
        "description": "A chunk of the config-derived catalog. Chunks are merged; 'reset' (sent on the first chunk of a fresh export) clears the catalog first.",
        "properties": {
          "reset": {
            "type": "boolean"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TypeConfig"
            }
          }
        }
      },
      "CommandsList": {
        "type": "object",
        "properties": {
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "type": {
                  "type": "string"
                },
                "args": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "Ack": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "result": {
            "description": "Any JSON value; recorded as the command result."
          }
        }
      }
    }
  }
}
