{
  "name": "lootmaster",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"server,client\" -c \"bgBlue.bold,bgGreen.bold\" \"npm run server:dev\" \"vite\"",
    "server": "node server/index.js",
    "server:dev": "node server/index.js --dev",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@untitledui/icons": "^0.0.22",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "moment": "^2.30.1",
    "react": "^19.1.1",
    "react-aria-components": "^1.17.0",
    "react-calendar": "^6.0.0",
    "react-clock": "^6.0.0",
    "react-datetime-picker": "^7.0.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.9.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "7.1.5",
    "vitest": "^2.1.8"
  }
}
